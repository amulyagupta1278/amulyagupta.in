# ─────────────────────────────────────────────────────────────────────────────
# SEO Autonomous Runtime — Environment Variables
# amulyagupta.in
#
# Copy this file to .env for local development.
# In production, set these as GitHub Actions Secrets.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ────────────────────────────────────────────────────────────────────
SITE_URL=https://amulyagupta.in
REPORT_EMAIL=amulyagupta2001@gmail.com

# ── Google Sheets Persistence ────────────────────────────────────────────────
# The spreadsheet ID from the Google Sheets URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Full JSON key for the Google service account.
# Paste the raw JSON content (not base64 encoded).
# The service account must have Editor access to the spreadsheet.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Email Delivery (Gmail) ───────────────────────────────────────────────────
# Gmail address used as the sender.
GMAIL_SENDER=yourname@gmail.com

# Gmail App Password (NOT your regular Gmail password).
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled.
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Google APIs ──────────────────────────────────────────────────────────────
# PageSpeed Insights API key (optional — increases rate limit from 25 to 25,000/day).
# Create at: https://console.cloud.google.com/apis/credentials
# Enable: PageSpeed Insights API
PAGESPEED_API_KEY=

# Google Search Console credentials (optional — enables Skill 18 live GSC data).
# Service account JSON with GSC property owner access.
GOOGLE_SEARCH_CONSOLE_CREDENTIALS=

# Google Analytics credentials (optional — enables Skill 19 live GA4 data).
# Service account JSON with GA4 property viewer access.
GOOGLE_ANALYTICS_CREDENTIALS=

# ── Runtime Control ──────────────────────────────────────────────────────────
# Skill group: 1=Foundational (4 skills), 2=+Technical (10 skills), 3=All 23
ENABLED_SKILL_GROUP=3

# Force a specific skill ID (1-23) or 'auto' for sequential rotation.
SKILL_OVERRIDE=auto

# Force re-initialize Google Sheets structure (use only on first deploy).
FORCE_INIT=false

# Send weekly summary email in addition to daily brief.
SEND_WEEKLY_SUMMARY=false

# ── GitHub (injected automatically by GitHub Actions — do not set manually) ──
# GITHUB_TOKEN=
# GITHUB_REPOSITORY=
# GITHUB_REF=
# GITHUB_EVENT_NAME=
